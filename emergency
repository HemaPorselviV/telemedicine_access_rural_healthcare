<div class="container">

<h2>🚑 Emergency Contact</h2>

<div class="card">
<h3>🚑 Ambulance</h3>
<p>Emergency Number: <strong>108</strong></p>
<button onclick="callAmbulance()">Call Ambulance</button>
</div>

<div class="card">
<h3>🏥 Hospital Helpline</h3>
<p>Phone: +91 98765 43210</p>
<button onclick="callHospital()">Call Hospital</button>
</div>

<div class="card">
<h3>👨‍⚕️ Emergency Doctor</h3>
<p>Dr. Kumar</p>
<p>Phone: +91 98765 11111</p>
<button onclick="callDoctor()">Call Doctor</button>
