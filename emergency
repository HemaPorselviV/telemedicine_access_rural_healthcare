    margin:40px auto;
    background:white;
    padding:30px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.2);
}

h2{
    text-align:center;
    color:#d62828;
    margin-bottom:25px;
}

.card{
    background:#f8f9fa;
    padding:20px;
    margin:15px 0;
    border-left:6px solid #d62828;
    border-radius:8px;
}

.card h3{
    color:#0077b6;
}

button{
    padding:10px 20px;
    background:#d62828;
    color:white;
    border:none;
    border-radius:6px;
    cursor:pointer;
    margin-top:10px;
}

button:hover{
    background:#a4133c;
}

</style>

