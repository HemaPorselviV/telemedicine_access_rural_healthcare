<button onclick="openMap()">Open Google Maps</button>
</div>

</div>

<footer>
<p>© 2026 TeleMedicine Access for Rural Healthcare</p>
</footer>

<script>

function callAmbulance(){
alert("Calling Ambulance (108)...");
}

function callHospital(){
alert("Calling Hospital...");
}

function callDoctor(){
alert("Calling Emergency Doctor...");
}

function openMap(){
window.open("https://maps.google.com","_blank");
}

</script>

