    padding:30px;
    border-radius:12px;
    box-shadow:0 5px 20px rgba(0,0,0,0.2);
}

.appointment h2{
    text-align:center;
    color:#0077b6;
    margin-bottom:20px;
}

.appointment input,
.appointment select,
.appointment textarea{
    width:100%;
    padding:12px;
    margin:10px 0;
    border:1px solid #ccc;
    border-radius:6px;
    font-size:16px;
}

.appointment button{
    width:100%;
    padding:12px;
    background:#0077b6;
    color:white;
    border:none;
    border-radius:6px;
    font-size:18px;
    cursor:pointer;
}

.appointment button:hover{
    background:#023e8a;
}

</style>

